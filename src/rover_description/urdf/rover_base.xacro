<?xml version="1.0"?>

<robot name="chaska_rover" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- ============================
         ROVER DIMENSIONS (parametric)
         ============================ -->
    <xacro:property name="chassis_length" value="0.710"/>
    <xacro:property name="chassis_width"  value="0.510"/>
    <xacro:property name="chassis_height" value="0.20"/>
    <xacro:property name="chassis_mass"   value="15.0"/>

    <xacro:property name="support_length" value="0.60"/>
    <xacro:property name="support_width"  value="0.10"/>
    <xacro:property name="support_height" value="0.10"/>
    <xacro:property name="support_mass"   value="1.0"/>

    <xacro:property name="yaw_size_x" value="0.10"/>
    <xacro:property name="yaw_size_y" value="0.10"/>
    <xacro:property name="yaw_size_z" value="0.15"/>
    <xacro:property name="yaw_mass"   value="1.0"/>

    <xacro:property name="wheel_radius" value="0.111"/>
    <xacro:property name="wheel_width"  value="0.12"/>
    <xacro:property name="wheel_mass"   value="0.8"/>

    <!-- wheel_support positions relative to base_link -->
    <xacro:property name="support_x_offset" value="0.0"/>
    <xacro:property name="support_y_offset" value="0.255"/>
    <xacro:property name="support_z_offset" value="0.075"/>

    <!-- yaw positions relative to wheel_support -->
    <xacro:property name="yaw_x_front"  value="0.419"/>
    <xacro:property name="yaw_x_rear"   value="-0.419"/>
    <xacro:property name="yaw_y_offset" value="0.169"/>
    <xacro:property name="yaw_z_offset" value="-0.0225"/>

    <!-- wheel positions relative to yaw -->
    <xacro:property name="wheel_x_offset" value="0.0"/>
    <xacro:property name="wheel_y_offset" value="0.0119"/>
    <xacro:property name="wheel_z_offset" value="-0.1765"/>

    <!-- ============================
         INERTIA MACROS
         ============================ -->

    <!-- Solid box: x=length, y=width, z=height -->
    <xacro:macro name="box_inertia" params="m x y z">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia
                ixx="${(m/12)*(y*y + z*z)}" ixy="0" ixz="0"
                iyy="${(m/12)*(x*x + z*z)}" iyz="0"
                izz="${(m/12)*(x*x + y*y)}"/>
        </inertial>
    </xacro:macro>

    <!-- Solid cylinder: axis along Y (wheel convention) -->
    <xacro:macro name="cylinder_inertia_y" params="m r l">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="${m}"/>
            <inertia
                ixx="${(m/12)*(3*r*r + l*l)}" ixy="0" ixz="0"
                iyy="${(m/2)*r*r}"             iyz="0"
                izz="${(m/12)*(3*r*r + l*l)}"/>
        </inertial>
    </xacro:macro>

    <!-- ============================
         LINK MACROS
         ============================ -->

    <!--
        wheel_support: rocker arm, fixed to base_link.
        name    → creates ${name}_link  +  ${name}_joint
        reflect → -1 left side, +1 right side (mirrors the STL)
        Collision: box 0.60 × 0.10 × 0.10 m
    -->
    <!--
        passive=0 → fixed joint (left side, anchors the chassis)
        passive=1 → revolute joint around X axis (right side, terrain compliance)
                    Rotates ±15° with damping so the rover tilts on uneven terrain
                    without oscillating like a pendulum.
    -->
    <xacro:macro name="wheel_support" params="name x_pos y_pos reflect passive:=0">
        <link name="${name}_link">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 ${-1.5708*reflect}"/>
                <geometry>
                    <mesh filename="package://rover_description/meshes/wheel_support.stl" scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="gray">
                    <color rgba="0.5 0.5 0.5 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="${support_length} ${support_width} ${support_height}"/>
                </geometry>
            </collision>
            <xacro:box_inertia m="${support_mass}"
                               x="${support_length}"
                               y="${support_width}"
                               z="${support_height}"/>
        </link>

        <!-- Fixed side: rigid attachment to chassis -->
        <xacro:if value="${not passive}">
            <joint name="${name}_joint" type="fixed">
                <parent link="base_link"/>
                <child link="${name}_link"/>
                <origin xyz="${x_pos} ${y_pos} ${support_z_offset}" rpy="0 0 0"/>
            </joint>
        </xacro:if>

        <!-- Passive side: revolute around Y (pitch/rocker axis) for terrain compliance.
             Rotates around Y so front and rear wheels on this side rise/fall together
             like a rocker arm, accommodating lateral slopes and obstacles. -->
        <xacro:unless value="${not passive}">
            <joint name="${name}_joint" type="revolute">
                <parent link="base_link"/>
                <child link="${name}_link"/>
                <origin xyz="${x_pos} ${y_pos} ${support_z_offset}" rpy="0 0 0"/>
                <axis xyz="0 1 0"/>
                <limit lower="-0.45" upper="0.45" effort="0" velocity="100"/>
                <dynamics damping="5.0" friction="0.5"/>
            </joint>
        </xacro:unless>
    </xacro:macro>

    <!--
        rover_yaw: steering joint, child of a wheel_support.
        name    → creates ${name}_yaw  +  ${name}_yaw_joint
        parent  → name of the parent wheel_support (e.g. "left_support")
        reflect → -1 left side, +1 right side
        Collision: box 0.10 × 0.10 × 0.15 m
    -->
    <xacro:macro name="rover_yaw" params="name parent x_pos y_pos reflect">
        <link name="${name}_yaw">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 ${-1.5708*reflect}"/>
                <geometry>
                    <mesh filename="package://rover_description/meshes/yaw.stl" scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="black">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <geometry>
                    <box size="${yaw_size_x} ${yaw_size_y} ${yaw_size_z}"/>
                </geometry>
            </collision>
            <xacro:box_inertia m="${yaw_mass}"
                               x="${yaw_size_x}"
                               y="${yaw_size_y}"
                               z="${yaw_size_z}"/>
        </link>

        <joint name="${name}_yaw_joint" type="continuous">
            <parent link="${parent}_link"/>
            <child link="${name}_yaw"/>
            <origin xyz="${x_pos} ${y_pos} ${yaw_z_offset}" rpy="0 0 0"/>
            <axis xyz="0 0 1"/>
            <dynamics damping="0.2"/>
        </joint>
    </xacro:macro>

    <!--
        rover_wheel: spinning wheel, child of a yaw link.
        name    → creates ${name}_wheel  +  ${name}_wheel_joint
        parent  → name of the parent yaw (e.g. "front_left")
        reflect → -1 left side, +1 right side
        Collision: cylinder r=0.111 m, l=0.12 m (axis Y)
    -->
    <xacro:macro name="rover_wheel" params="name parent x_pos y_pos reflect">
        <link name="${name}_wheel">
            <visual>
                <origin xyz="0 0 0" rpy="0 0 ${1.5708*reflect}"/>
                <geometry>
                    <mesh filename="package://rover_description/meshes/wheel.stl" scale="0.001 0.001 0.001"/>
                </geometry>
                <material name="black">
                    <color rgba="0.1 0.1 0.1 1.0"/>
                </material>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
            </collision>
            <xacro:cylinder_inertia_y m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
        </link>

        <joint name="${name}_wheel_joint" type="continuous">
            <parent link="${parent}_yaw"/>
            <child link="${name}_wheel"/>
            <origin xyz="${x_pos} ${y_pos} ${wheel_z_offset}" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
            <dynamics damping="0.2"/>
        </joint>
    </xacro:macro>

    <!-- ============================
         LINKS
         ============================ -->

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 1.5708"/>
            <geometry>
                <mesh filename="package://rover_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="orange">
                <color rgba="0.9 0.5 0.1 1.0"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
            </geometry>
        </collision>
        <xacro:box_inertia m="${chassis_mass}"
                           x="${chassis_length}"
                           y="${chassis_width}"
                           z="${chassis_height}"/>
    </link>

    <link name="imu">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.03 0.03 0.01"/>
            </geometry>
            <material name="gray">
                <color rgba="0.3 0.3 0.3 1"/>
            </material>
        </visual>
    </link>

    <link name="laser">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.035" length="0.05"/>
            </geometry>
            <material name="black">
                <color rgba="0.1 0.1 0.1 1"/>
            </material>
        </visual>
    </link>

    <link name="camera">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.025 0.08 0.03"/>
            </geometry>
            <material name="gray">
                <color rgba="0.3 0.3 0.3 1"/>
            </material>
        </visual>
    </link>

    <link name="camera_optical_frame"/>

    <!-- ============================
         JOINTS
         ============================ -->

    <joint name="base_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.280" rpy="0 0 0"/>
    </joint>

    <!-- ── Level 1: wheel supports ── -->
    <!-- Left: fixed — anchors the chassis, no rotation -->
    <xacro:wheel_support name="left_support"  x_pos="${support_x_offset}" y_pos=" ${support_y_offset}" reflect="-1" passive="0"/>
    <!-- Right: passive revolute around X — terrain compliance (±15°, damped) -->
    <xacro:wheel_support name="right_support" x_pos="${support_x_offset}" y_pos="-${support_y_offset}" reflect=" 1" passive="1"/>

    <!-- ── Level 2: yaw links (steering, one per wheel) ── -->
    <xacro:rover_yaw name="front_left"  parent="left_support"  x_pos="${yaw_x_front}" y_pos=" ${yaw_y_offset}" reflect="-1"/>
    <xacro:rover_yaw name="front_right" parent="right_support" x_pos="${yaw_x_front}" y_pos="-${yaw_y_offset}" reflect=" 1"/>
    <xacro:rover_yaw name="rear_left"   parent="left_support"  x_pos="${yaw_x_rear}"  y_pos=" ${yaw_y_offset}" reflect="-1"/>
    <xacro:rover_yaw name="rear_right"  parent="right_support" x_pos="${yaw_x_rear}"  y_pos="-${yaw_y_offset}" reflect=" 1"/>

    <!-- ── Level 3: wheels (drive, child of their yaw) ── -->
    <xacro:rover_wheel name="front_left"  parent="front_left"  x_pos="${wheel_x_offset}" y_pos="-${wheel_y_offset}" reflect="-1"/>
    <xacro:rover_wheel name="front_right" parent="front_right" x_pos="${wheel_x_offset}" y_pos=" ${wheel_y_offset}" reflect=" 1"/>
    <xacro:rover_wheel name="rear_left"   parent="rear_left"   x_pos="${wheel_x_offset}" y_pos="-${wheel_y_offset}" reflect="-1"/>
    <xacro:rover_wheel name="rear_right"  parent="rear_right"  x_pos="${wheel_x_offset}" y_pos=" ${wheel_y_offset}" reflect=" 1"/>

    <!-- ── Sensors ── -->
    <joint name="imu_joint" type="fixed">
        <parent link="base_link"/>
        <child link="imu"/>
        <origin xyz="0 0 ${chassis_height/2 + 0.01}" rpy="0 0 0"/>
    </joint>

    <!-- Livox 3D LiDAR: montado adelante-arriba del chasis,
         inclinado -10° en pitch para captar el suelo delante del rover -->
    <joint name="laser_joint" type="fixed">
        <parent link="base_link"/>
        <child link="laser"/>
        <origin xyz="${chassis_length/2 - 0.01} 0 ${chassis_height/2 + 0.12}" rpy="0 0.1745 0"/>
    </joint>

    <joint name="camera_joint" type="fixed">
        <parent link="base_link"/>
        <child link="camera"/>
        <origin xyz="${chassis_length/2} 0 ${chassis_height/2 + 0.02}" rpy="0 0 0"/>
    </joint>

    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera"/>
        <child link="camera_optical_frame"/>
        <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>

</robot>
